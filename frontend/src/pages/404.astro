---
import Layout from '../layouts/Layout.astro';
import '../index.css';
---

<Layout title="Page Not Found - CozyPixels" description="The page you are looking for does not exist.">
  <main style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; text-align: center;">
    <div style="margin-bottom: 2rem; opacity: 0.8; color: #2f365e;">
      <svg width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        <circle cx="12" cy="12" r="4"/>
      </svg>
    </div>
    <h1 class="font-display" style="font-size: 6rem; font-weight: 850; margin-bottom: 1rem; color: #1e2444; letter-spacing: -0.06em;">404</h1>
    <h2 class="font-display" style="font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem; color: #2f365e;">Oops! A sleepy cat knocked this page off the server.</h2>
    <p style="color: #626d86; max-width: 450px; margin: 0 auto 3rem; font-size: 1.1rem; line-height: 1.6;">We couldn't find the page you were looking for. It might have been moved, deleted, or perhaps it never existed.</p>
    
    <a href="/" class="hero-cta-primary" style="display: inline-flex; align-items: center; justify-content: center;">
      Take Me Home
    </a>
  </main>
</Layout>
