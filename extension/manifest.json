{
  "manifest_version": 3,
  "name": "Cozy Engine",
  "version": "1.0.0",
  "description": "Your serene digital sanctuary in every new tab.",
  "permissions": ["storage", "alarms"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  }
}
