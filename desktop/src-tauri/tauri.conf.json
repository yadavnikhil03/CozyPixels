{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CozyPixels",
  "version": "1.0.1",
  "identifier": "com.cozypixels.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CozyPixels",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3001; img-src 'self' cozy: asset: http://localhost:3001 https://* http://* data:;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yadavnikhil03/CozyPixels/releases/latest/download/latest.json"
      ],
      "pubkey": "UPDATE_ME_WITH_YOUR_GENERATED_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
