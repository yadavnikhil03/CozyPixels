{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CozyPixels",
  "version": "1.0.9",
  "identifier": "com.cozypixels.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CozyPixels",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' cozy: blob: data: https:; connect-src 'self' https://cdn.jsdelivr.net https://cozy-pixels.vercel.app https://cozy-pixels.onrender.com; script-src 'self';"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yadavnikhil03/CozyPixels/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBOUEzNThCQjU4QThBREYKUldUZmlvcTFpeldhT3FmYjVWUklrM1BZVVlvTUw4YzFqdzJINjRTamZxcWVnaXB0UENIUitOWTEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
